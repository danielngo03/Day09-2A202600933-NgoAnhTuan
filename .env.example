# Cấu hình Chat Model mặc định
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
LLM_TEMPERATURE=0

# API Keys cho các Provider (Điền key thực tế của bạn)
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Cấu hình OpenRouter (Cho Chat Model hoặc Mô hình Tạo ảnh Riverflow)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=VinShop Shopping Assistant

# Cấu hình RAG & Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=4

# Cấu hình bổ sung cho Ollama hoặc Custom Provider (Tùy chọn)
# OLLAMA_BASE_URL=http://localhost:11434
# CUSTOM_LLM_MODEL=your-custom-model-name
# CUSTOM_LLM_BASE_URL=your-custom-base-url
# CUSTOM_LLM_API_KEY=your-custom-api-key

# Cấu hình Đăng nhập & Lịch sử của Chainlit UI
CHAINLIT_AUTH_SECRET=vinshop-local-dev-secret-change-me
CHAINLIT_AUTH_USER=admin
CHAINLIT_AUTH_PASSWORD=vinshop
